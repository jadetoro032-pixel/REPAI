{
  "name": "repai-meeting-delegate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "tsx src/server/teamsCallServer.ts",
    "test": "vitest run",
    "build": "tsc --noEmit",
    "demo": "tsx src/demo/runDemo.ts",
    "demo:card": "tsx src/demo/exportTeamsCard.ts",
